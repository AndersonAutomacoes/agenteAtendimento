# Copie para .env e preencha (Docker Compose carrega .env automaticamente na raiz).
# Obtenha a chave em: https://aistudio.google.com/apikey

# Obrigatório para chat Gemini + embeddings RAG
GEMINI_API_KEY=

# Opcional: modelo de chat (free tier costuma ter cota para 1.5 Flash; 2.0 Flash pode dar 429 limit:0 sem faturação)
# GEMINI_CHAT_MODEL=gemini-1.5-flash

# Opcional: só se ativar cerebro.ai.openai-chat-enabled=true no application.yml
# OPENAI_API_KEY=
