# Copie para .env e preencha (Docker Compose carrega .env automaticamente na raiz).
# Obtenha a chave em: https://aistudio.google.com/apikey

# Obrigatório para chat Gemini + embeddings RAG
GEMINI_API_KEY=

# Opcional: modelo de chat (free tier costuma ter cota para 1.5 Flash; 2.0 Flash pode dar 429 limit:0 sem faturação)
# GEMINI_CHAT_MODEL=gemini-1.5-flash

# --- WhatsApp Evolution (Baileys): botões interativos são pouco fiáveis; omissão = lista em texto ---
# CEREBRO_WHATSAPP_EVOLUTION_SEND_INTERACTIVE_BUTTONS=false
# CEREBRO_WHATSAPP_EVOLUTION_MIRROR_SLOTS_TEXT=false

# --- Google Calendar (agendamento por tenant: google_calendar_id na tenant_configuration) ---
# Por defeito (application.yml e Docker Compose): CEREBRO_GOOGLE_CALENDAR_MOCK=false + Google Calendar API.
# Para testar sem credenciais Google: CEREBRO_GOOGLE_CALENDAR_MOCK=true (MockAppointmentSchedulingService; sem eventos no Google).
# Com API real, credenciais (uma das opções):
# (A) Docker Compose: monta por defeito ./bootstrap/src/main/resources/credentials.json → /run/google-calendar-sa.json
#     e define GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON_PATH=/run/google-calendar-sa.json (já no docker-compose).
#     Para outro ficheiro no host: GOOGLE_CALENDAR_CREDENTIALS_FILE=./secrets/google-calendar-sa.json
# (B) Local (sem Docker): credentials.json em bootstrap/src/main/resources ou GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON_PATH
# CEREBRO_GOOGLE_CALENDAR_ID=... (opcional; se vazio usa client_email do JSON)
# CEREBRO_GOOGLE_CALENDAR_ZONE=America/Sao_Paulo (slots; eventos em America/Sao_Paulo)

# Opcional: só se ativar cerebro.ai.openai-chat-enabled=true no application.yml
# OPENAI_API_KEY=

# --- Firebase Authentication (portal) ---
# O backend valida ID tokens com o Admin SDK: precisa do MESMO projeto que o frontend.
# application.yml: cerebro.firebase.enabled vem de CEREBRO_FIREBASE_ENABLED (omissão = true).
# Docker Compose: usa CEREBRO_FIREBASE_ENABLED do .env (predefinição false se não definir).
#
# Para ativar no Docker: no .env na raiz do repositório, por exemplo:
#   CEREBRO_FIREBASE_ENABLED=true
#   FIREBASE_PROJECT_ID=seu-projeto-id
#   FIREBASE_SERVICE_ACCOUNT_JSON_PATH=/run/firebase.json
# e no docker-compose monte o JSON: volumes: - ./secrets/firebase-adminsdk.json:/run/firebase.json:ro
#
# Execução local (sem Docker): conta de serviço com "Firebase Authentication Admin"
#   CEREBRO_FIREBASE_ENABLED=true
#   FIREBASE_PROJECT_ID=your-project-id
#   FIREBASE_SERVICE_ACCOUNT_JSON_PATH=C:/caminho/serviceAccount.json
# ou GOOGLE_APPLICATION_CREDENTIALS apontando para o mesmo JSON

# Frontend (Next.js em atendimento-frontEnd/atendimento-frontend): mesmo projeto Firebase
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
# NEXT_PUBLIC_FIREBASE_APP_ID=
#
# Convites (portal): inserir em tenant_invite com code_hash = SHA-256 em hex minúsculo do código em texto.
# Testes de integração: application-test.yml usa cerebro.firebase.enabled=false (sem SDK Firebase).
